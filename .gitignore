# Secrets — never commit real API keys / DB passwords
api/config.local.php

# User-generated content (stays local, not part of source control)
assets/user_photos/*
!assets/user_photos/.gitkeep
assets/uploaded_images/*
!assets/uploaded_images/.gitkeep
assets/generated_designs/*
!assets/generated_designs/.gitkeep

# Frontend
frontendreact/node_modules/
frontendreact/dist/
frontendreact/build/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# Generated by build-pages.sh for Cloudflare Pages - regenerated on every
# deploy, not source, never commit it
pages-deploy/

# Generated by build-backend.sh for InfinityFree - regenerated on every
# deploy, not source, never commit it
backend-deploy.zip
