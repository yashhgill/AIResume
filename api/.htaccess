# CORS headers are handled by PHP (config.php) to avoid duplication
# Removed Apache CORS headers to prevent duplicate Access-Control-Allow-Origin header

# Handle preflight OPTIONS request - PHP will handle this in config.php
# Keeping this commented out as PHP handles OPTIONS in config.php
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{REQUEST_METHOD} OPTIONS
#     RewriteRule ^(.*)$ $1 [R=200,L]
# </IfModule>

# Enable PHP error reporting for development (remove in production)
php_flag display_errors On
php_value error_reporting E_ALL

